{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "start:worker": "node dist/src/worker.js",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^2.0.0-rc.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.15.19",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}

{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDirs": ["src", "jobs", "services"],
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "jobs/**/*.ts", "jobs/**/*.d.ts", "services/**/*.ts", "services/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
